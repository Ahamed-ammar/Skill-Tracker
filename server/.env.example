# Required — get your free key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT secret — change this to a long random string in production
JWT_SECRET_KEY=curator-ai-super-secret-jwt-key-change-in-prod

# Optional — for live job search (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPID_API_KEY=your_rapidapi_key_here

# Optional — PostgreSQL for session persistence (leave blank to skip)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server port (default: 8000)
PORT=8000
