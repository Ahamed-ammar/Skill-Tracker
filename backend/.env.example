# Copy this file to .env and fill in your values
# Never commit .env to git

# Required — get free key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT secret — use a long random string
JWT_SECRET_KEY=your_random_secret_here

# Optional — for live job search (https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch)
RAPID_API_KEY=your_rapidapi_key_here

# Optional — PostgreSQL connection string (leave blank to skip DB persistence)
DATABASE_URL=
